{
  "name": "filecoin-nova",
  "version": "0.7.2",
  "description": "Clone, deploy, and manage websites on Filecoin Onchain Cloud with ENS resolution",
  "type": "module",
  "main": "./dist/deploy.js",
  "exports": {
    ".": "./dist/deploy.js",
    "./ens": "./dist/ens.js",
    "./upload": "./dist/upload.js",
    "./clone": "./dist/clone.js",
    "./manage": "./dist/manage.js"
  },
  "bin": {
    "nova": "./dist/cli.js",
    "nova-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "SKILL.md"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "postinstall": "npx playwright install-deps chromium 2>/dev/null || true",
    "build": "tsc && cp src/worker.js dist/worker.js && chmod +x dist/cli.js dist/mcp.js",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js"
  },
  "keywords": [
    "filecoin",
    "ipfs",
    "ens",
    "deploy",
    "decentralized",
    "web3"
  ],
  "author": "FilOz",
  "license": "MIT",
  "dependencies": {
    "@filoz/synapse-core": "^0.2.3",
    "@filoz/synapse-sdk": "^0.39.0",
    "@helia/unixfs": "^7.0.4",
    "@ipld/car": "^5.4.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@playwright/browser-chromium": "^1.58.2",
    "blockstore-core": "^6.1.2",
    "ethers": "^6.13.0",
    "multiformats": "^13.0.0",
    "playwright": "^1.58.2",
    "viem": "^2.47.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@playwright/browser-chromium"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
